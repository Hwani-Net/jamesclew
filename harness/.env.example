# JamesClaw Agent — Environment Variables Template
# Copy to .env in your home directory: cp .env.example ~/.harness.env
# Then: source ~/.harness.env (or set up shell auto-load)

# ─── 필수 (Required) ───
# Perplexity API (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# Tavily API (https://tavily.com/) — 6키 로테이션 권장
TAVILY_API_KEY=

# Obsidian Vault 절대경로 (영구 지식 저장)
OBSIDIAN_VAULT=/path/to/your/Obsidian-Vault

# ─── 선택 (Optional) ───
# Telegram Bot 알림 (둘 다 비어있으면 알림 비활성)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI (Vision 검증, codex CLI 등에서 사용)
OPENAI_API_KEY=

# Tavily 키 로테이션 파일 (기본: ~/.claude/tavily-keys.json)
# TAVILY_KEYS_FILE=

# tavily-mcp 설치 경로 (기본: npm root -g 자동 탐지)
# TAVILY_MCP_PATH=

# ─── 외부 도구 ───
# 외부 모델 검수에 사용. 별도 설치 필요:
# - codex CLI: npm i -g @openai/codex
# - antigravity (opencode): https://github.com/sst/opencode
# - gemini CLI: npm i -g @google/generative-ai-cli
