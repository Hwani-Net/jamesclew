{
  "env": {
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}",
    "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
    "TAVILY_API_KEY": "${TAVILY_API_KEY}"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "NotebookEdit(*)",
      "TodoWrite(*)",
      "mcp__lazy-mcp__*",
      "mcp__windows-mcp__*",
      "mcp__plugin_telegram_telegram__*",
      "Plugin:telegram:*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(*format*C:*)",
      "Bash(*Remove-Item*-Recurse*-Force*C:\\*)",
      "Bash(*del*/s*/q*C:\\*)",
      "Bash(*|*curl*)",
      "Bash(*|*wget*)",
      "Bash(*&&*rm -rf*)",
      "Bash(*;*rm -rf*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); FILE=$(echo \"$INPUT\" | grep -oP '\"file_path\"\\s*:\\s*\"\\K[^\"]+' 2>/dev/null || echo \"$INPUT\" | grep -oP '\"path\"\\s*:\\s*\"\\K[^\"]+' 2>/dev/null); if [ -z \"$FILE\" ]; then exit 0; fi; case \"$FILE\" in *.env|*.env.*|*credentials*|*secrets*|*secret*|*.pem|*.key) echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"deny\\\",\\\"permissionDecisionReason\\\":\\\"Protected file: $FILE\\\"}}\" >&2; exit 2;; esac'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-memory-write.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/enforce-build-transition.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/quality-gate.sh pre-commit",
            "if": "Bash(git commit *)",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/irreversible-alert.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-deploy.sh",
            "if": "Bash(*firebase deploy*)",
            "timeout": 30000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-subagent.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-deploy.sh",
            "if": "Bash(*firebase deploy*)",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/enforce-review.sh",
            "if": "Bash(*firebase deploy*)",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/error-telegram.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/loop-detector.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-edit-dispatcher.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/quality-gate.sh post-test",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/loop-detector.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --experimental-strip-types \"$HOME/.claude/hooks/user-prompt.ts\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/pre-compact-snapshot.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/audit-session.sh --compact",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "bash -c 'bash $HOME/.claude/scripts/self-evolve.sh --apply 2>/dev/null'",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "node --experimental-strip-types \"$HOME/.claude/hooks/curation.ts\"",
            "timeout": 120000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/stop-dispatcher.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash $HOME/.claude/hooks/telegram-notify.sh compact'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node --experimental-strip-types \"$HOME/.claude/hooks/session-start.ts\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash $HOME/.claude/hooks/telegram-notify.sh start; echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"SessionStart\\\",\\\"additionalContext\\\":\\\"[INIT] JamesClaw Agent. 즉시실행(할까요금지), Built-in>Bash>MCP, 토큰효율최우선, 에러3회재시도후보고.\\\"}}\"'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node --experimental-strip-types \"$HOME/.claude/hooks/session-start.ts\"",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "telegram@claude-plugins-official": true,
    "awesome-statusline@awesome-claude-plugins": true
  },
  "language": "korean",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/awesome-statusline.sh"
  }
}
